[Unit]
Description=SparkKit Receipts API
After=network.target

[Service]
User=sharma
# openclaw CLI (extraction backend) needs HOME for its ~/.openclaw state
Environment=HOME=/home/sharma
EnvironmentFile=/etc/sparkkit-receipts.env
ExecStart=/usr/bin/python3 /srv/sparkkit/receipts/server.py
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
